{
  "name": "zrochet-web",
  "private": true,
  "scripts": {
    "dev": "prisma generate && npm run generate:catalog && next dev",
    "dev:clean": "node scripts/clean-next.js && npm run dev",
    "build": "prisma generate && npm run generate:catalog && next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "generate:catalog": "node scripts/generate-catalog.js",
    "generate:minibags": "node scripts/generate-catalog.js",
    "watch:minibags": "node scripts/watch-minibag-catalog.js",
    "db:seed": "node scripts/seed-database.js",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "next": "^15.3.3",
    "prisma": "^6.19.0",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^22.15.21",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3"
  }
}
