# ─── Local development ───
# Copy this file to .env.local and fill in values.

NEXT_PUBLIC_SITE_URL="http://localhost:3000"
ADMIN_PASSWORD="zrochet-local"

# Railway PUBLIC database URL (required for admin + orders locally)
# Railway → Postgres → Connect → Public Network
DATABASE_URL="postgresql://postgres:PASSWORD@HOST.railway.app:PORT/railway"

NEXT_PUBLIC_UPI_ID="yourname@oksbi"
NEXT_PUBLIC_UPI_PAYEE_NAME="Zrochet"

# Optional — thank-you email when admin approves payment
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Zrochet <your-email@gmail.com>"

# ─── Railway production (web service variables) ───
# NEXT_PUBLIC_SITE_URL="https://zrochetcurserrailway-production.up.railway.app"
