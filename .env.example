# Database (Railway PostgreSQL)
# Use the PUBLIC URL for local development (Railway → Postgres → Connect → Public URL)
# Use the internal URL on Railway (postgres.railway.internal) — set automatically when linked
DATABASE_URL="postgresql://postgres:PASSWORD@HOST:PORT/railway"

# Admin portal password — change this!
ADMIN_PASSWORD="your-secure-admin-password"

# Optional: your deployed site URL
NEXT_PUBLIC_SITE_URL="https://zrochetcurserrailway-production.up.railway.app"

# UPI payment (storefront)
NEXT_PUBLIC_UPI_ID="yourname@oksbi"
NEXT_PUBLIC_UPI_PAYEE_NAME="Zrochet"

# Email — thank-you email when admin approves a payment (Gmail example)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Zrochet <your-email@gmail.com>"
