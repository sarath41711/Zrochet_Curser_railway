# Database (Railway PostgreSQL)
# Use the PUBLIC URL for local development (Railway → Postgres → Connect → Public URL)
# Use the internal URL on Railway (postgres.railway.internal) — set automatically when linked
DATABASE_URL="postgresql://postgres:PASSWORD@HOST:PORT/railway"

# Admin portal password — change this!
ADMIN_PASSWORD="your-secure-admin-password"

# Optional: your deployed site URL
NEXT_PUBLIC_SITE_URL="https://zrochetcurserrailway-production.up.railway.app"
